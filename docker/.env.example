# =====================================================
# LeadFlow Platform - Environment Configuration
# =====================================================

# Node Environment
NODE_ENV=development

# PostgreSQL Database
POSTGRES_USER=leadflow
POSTGRES_PASSWORD=leadflow_secret_2024
POSTGRES_DB=leadflow

# JWT Secrets (Generate strong secrets for production)
JWT_SECRET=leadflow_jwt_secret_key_change_in_production
JWT_REFRESH_SECRET=leadflow_refresh_secret_key_change_in_production

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Google Maps API (for lead discovery)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# LinkedIn API
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Reddit API
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Twitter/X API
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Facebook API
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Product Hunt API
PRODUCT_HUNT_API_KEY=your_product_hunt_api_key

# Crunchbase API
CRUNCHBASE_API_KEY=your_crunchbase_api_key

# Supabase Storage
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Email Service (SendGrid/AWS SES)
SENDGRID_API_KEY=your_sendgrid_api_key

# WhatsApp Business API
WHATSAPP_BUSINESS_TOKEN=your_whatsapp_token

# Application URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Proxy Configuration (for scraping)
PROXY_ENABLED=false
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=